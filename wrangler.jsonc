{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tanstack-start-app",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": ["nodejs_compat"],
  // Custom server entry — wrappa o handler default do TanStack Start
  // com proxy /c/* pra Clarity (bypass de adblockers que bloqueiam
  // *.clarity.ms). Tudo fora de /c/* cai no handler padrão.
  "main": "./src/server-entry.ts",
}
